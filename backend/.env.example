# KyberGuard Public API — Environment Template
# Kopieren nach .env und Werte eintragen

# CORS — welche Origins dürfen die API nutzen
ALLOWED_ORIGINS=https://kyberguard.de,https://www.kyberguard.de

# CrowdSec LAPI (für echte Map-Daten)
# Ohne diese Variable: Fallback-Daten werden verwendet
CROWDSEC_LAPI_URL=http://172.18.0.4:8080
CROWDSEC_LAPI_KEY=dein-crowdsec-api-key-hier
