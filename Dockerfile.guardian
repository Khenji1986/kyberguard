FROM python:3.11-slim

WORKDIR /app

COPY requirements-monitor.txt .
RUN pip install --no-cache-dir -r requirements-monitor.txt

COPY security_monitor.py .
RUN groupadd -r guardian && useradd -r -g guardian -u 1002 guardian && \
    mkdir -p /app/backups && chown -R guardian:guardian /app

USER guardian

CMD ["python", "-u", "security_monitor.py"]
